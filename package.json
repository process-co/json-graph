{
  "name": "@process.co/json-graph",
  "version": "0.0.0-development",
  "packageManager": "pnpm@10.7.1",
  "description": "JSON-to-graph viewer using React Flow and elkjs",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts-resolve --format cjs,esm --out-dir dist --clean",
    "test": "vitest run",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "dev": "tsup --watch & storybook dev -p 6007",
    "chromatic": "pnpx chromatic"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "zustand": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/process-co/json-graph.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "scope": "@process.co"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  }
}
