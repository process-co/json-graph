{
  "name": "@process.co/json-graph",
  "version": "0.0.0-development",
  "packageManager": "pnpm@10.7.1",
  "description": "JSON-to-graph viewer using React Flow and elkjs",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts-resolve --format cjs,esm --out-dir dist --clean",
    "test": "vitest run",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "dev": "tsup --watch & storybook dev -p 6007",
    "chromatic": "pnpx chromatic"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@fortawesome/pro-regular-svg-icons": "^6.7.2",
    "@fortawesome/pro-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@storybook/addon-docs": "10.1.4",
    "@storybook/react": "10.1.4",
    "@storybook/react-vite": "10.1.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@xyflow/react": "^12.0.0",
    "chromatic": "^15.2.0",
    "clsx": "^2.1.1",
    "elkjs": "^0.9.2",
    "jsdom": "^25.0.0",
    "jsonc-parser": "^3.3.0",
    "react": "19.2.2",
    "react-dom": "19.2.2",
    "storybook": "10.1.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwindcss": "npm:tailwindcss@4.1.3",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-animated": "^2.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  }
}
